---
const footerLinks = [
  { href: '/about/', label: 'About' },
  { href: '/campaigns/', label: 'Campaigns' },
  { href: '/news/', label: 'News' },
  { href: '/friends/', label: 'Friends' },
  { href: '/shop/', label: 'Shop' },
  { href: '/media/', label: 'Media' },
  { href: '/contact/', label: 'Contact' },
  { href: '/privacy/', label: 'Privacy' },
  { href: '/corrections/', label: 'Corrections' },
  { href: '/governance/', label: 'Governance' }
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div>
      <a class="wordmark wordmark--footer" href="/">
        <img class="wordmark__logo" src="/brand/bite-mark-transparent-64.png" width="44" height="44" alt="" decoding="async" loading="lazy" />
        <span class="wordmark__text">
          <strong>BITE BACK PROJECT</strong>
          <small>ANIMAL ADVOCACY WITH TEETH</small>
        </span>
      </a>
      <p>
        Bite Back Project turns animal welfare evidence into lawful pressure, public tracking and practical reform work.
      </p>
      <div class="site-footer__acknowledgement">
        <p>BITE BACK PROJECT acknowledges the rightful owners and traditional caretakers of all land upon which it conducts operations.</p>
        <p>
          We recognise and pay respects to the Wurundjeri Woi Wurrung and Bunurong people of the Kulin Nation.
          <img src="/brand/aboriginal-flag.svg" width="30" height="18" alt="Aboriginal Flag" loading="lazy" decoding="async" />
        </p>
        <p>All site-specific content copyright (c) BITE BACK PROJECT 2026</p>
      </div>
    </div>
    <nav aria-label="Footer navigation">
      {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</footer>
