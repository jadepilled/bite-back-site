---
import { ArrowRight } from '@lucide/astro';
import ButtonLink from '@components/ButtonLink.astro';
import {
  campaignOriginClass,
  campaignOriginLabel,
  campaignPath,
  campaignRegionClass,
  campaignRegionLabel,
  formatList,
  severityLabel,
  severityRank,
  statusLabel
} from '@lib/content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  campaign: CollectionEntry<'campaigns'>;
  image?: CollectionEntry<'images'>['data'];
}

const { campaign, image } = Astro.props;
const searchText = [
  campaign.data.title,
  campaign.data.summary,
  campaign.data.issueType,
  campaign.data.desiredOutcome,
  campaign.data.affectedAnimals.join(' ')
].join(' ').toLowerCase();
---

<article
  class="campaign-card"
  data-campaign-card
  data-title={campaign.data.title.toLowerCase()}
  data-search={searchText}
  data-date={campaign.data.launchDate ?? ''}
  data-severity={severityRank(campaign.data.severity)}
  data-status={campaign.data.status}
  data-origin={campaign.data.origin}
  data-regions={campaign.data.regions.join('|')}
  data-time-left={campaign.data.timeLeftLabel ?? ''}
>
  {image && (
    <a class="campaign-card__image" href={campaignPath(campaign)} aria-label={`Read ${campaign.data.title}`}>
      <img src={image.src} alt={image.alt} loading="eager" decoding="async" />
    </a>
  )}
  <div class="campaign-card__body">
    <div class="campaign-tag-row" aria-label="Campaign tags">
      <span class={`label-chip label-chip--status-${campaign.data.status}`}>{statusLabel(campaign.data.status)}</span>
      <span class={`label-chip ${campaignOriginClass(campaign.data.origin)}`}>{campaignOriginLabel(campaign.data.origin)}</span>
      {campaign.data.regions.map((region) => (
        <span class={`label-chip ${campaignRegionClass(region)}`}>{campaignRegionLabel(region)}</span>
      ))}
      <span class={`label-chip label-chip--severity-${campaign.data.severity}`}>{severityLabel(campaign.data.severity)}</span>
      {campaign.data.timeLeftLabel && <span class="label-chip label-chip--time-left">{campaign.data.timeLeftLabel}</span>}
    </div>
    <p class="section-label">{campaign.data.issueType}</p>
    <h2>
      <a href={campaignPath(campaign)}>{campaign.data.title}</a>
    </h2>
    <p>{campaign.data.summary}</p>
    <dl class="campaign-facts">
      <div>
        <dt>Affected animals</dt>
        <dd>{formatList(campaign.data.affectedAnimals)}</dd>
      </div>
      <div>
        <dt>Decision-maker</dt>
        <dd>{campaign.data.decisionMakers[0]}</dd>
      </div>
      <div>
        <dt>Current action</dt>
        <dd>{campaign.data.primaryAction.label}</dd>
      </div>
    </dl>
    <ButtonLink href={campaignPath(campaign)} variant="secondary">
      Read the campaign
      <ArrowRight slot="icon" size={18} aria-hidden="true" />
    </ButtonLink>
  </div>
</article>
