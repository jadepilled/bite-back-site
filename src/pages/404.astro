---
import BaseLayout from '@layouts/BaseLayout.astro';
import ButtonLink from '@components/ButtonLink.astro';
---

<BaseLayout title="Page Not Found" description="The requested Bite Back page was not found.">
  <section class="page-header">
    <div class="container reading-width">
      <p class="section-label">404</p>
      <h1>Page not found.</h1>
      <p class="lede">This page is not published. Try the current campaigns or track record.</p>
      <div class="button-row">
        <ButtonLink href="/campaigns/" variant="primary">Current campaigns</ButtonLink>
        <ButtonLink href="/track-record/" variant="secondary">Track record</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
