---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import ButtonLink from '@components/ButtonLink.astro';
---

<BaseLayout
  title="Donate"
  description="Donations support Bite Back research, legal review, campaign infrastructure, public education and advocacy tools."
>
  <PageHeader
    eyebrow="Donate"
    title="Donation routing stays external until fundraising review is complete."
    intro="Donations support research, legal review, campaign infrastructure, public education and advocacy tools. Bite Back should publish donor-transparency rules and comply with fundraising law before soliciting at scale."
  />

  <section class="section" id="donation-readiness">
    <div class="container">
      <div class="pathway-grid">
        <div class="pathway">
          <strong>Fundraising review</strong>
          <p>Confirm legal structure, fundraising obligations and donor-transparency rules before launch.</p>
        </div>
        <div class="pathway">
          <strong>External processor</strong>
          <p>Use a vetted Raisely and Stripe-style flow rather than collecting payment data on GitHub Pages.</p>
        </div>
        <div class="pathway">
          <strong>Consent separation</strong>
          <p>Separate donation processing from campaign email consent and supporter records.</p>
        </div>
      </div>
      <div class="section-compact">
        <ButtonLink href="/governance/" variant="secondary">Review governance safeguards</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
