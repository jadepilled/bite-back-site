---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import StatusPill from '@components/StatusPill.astro';
import ButtonLink from '@components/ButtonLink.astro';
import { confidenceLabel, mapEntries, reviewLabel, severityLabel, statusLabel } from '@lib/content';

const campaignEntries = await getCollection('campaigns');
const campaigns = mapEntries(campaignEntries);
const campaignsById = new Map(campaignEntries.map((campaign) => [campaign.data.id, campaign]));
const progress = (await getCollection('progress')).sort((a, b) => b.data.date.localeCompare(a.data.date));
const platformUpdates = (await getCollection('platformUpdates')).sort((a, b) => b.data.date.localeCompare(a.data.date));
const corrections = [...campaigns.values()].flatMap((campaign) =>
  campaign.data.correctionHistory.map((correction) => ({
    campaign,
    correction
  }))
);
const actionCount = campaignEntries.length;
const testingActions = campaignEntries.filter((campaign) => campaign.data.primaryAction.status === 'testing').length;
const liveActions = campaignEntries.filter((campaign) => campaign.data.primaryAction.status === 'active').length;
const reviewQueue = campaignEntries.filter((campaign) =>
  campaign.data.legalReviewStatus !== 'approved' || campaign.data.scientificReviewStatus !== 'approved'
).length;
---

<BaseLayout
  title="Track Record"
  description="Bite Back track record page for campaign progress, corrections, review status and launch readiness."
>
  <PageHeader
    eyebrow="Track Record"
    title="Readiness, progress and receipts in one place."
    intro="Campaign progress, platform updates, review gates and correction records sit together so early testers can see what is live, what is blocked and what needs work."
  />

  <section class="section">
    <div class="container">
      <div class="metric-grid">
        <article class="pathway">
          <strong>{campaigns.size}</strong>
          <p>Public campaigns</p>
        </article>
        <article class="pathway">
          <strong>{platformUpdates.length + progress.length}</strong>
          <p>Updates across campaigns and platform work</p>
        </article>
        <article class="pathway">
          <strong>{liveActions}/{actionCount}</strong>
          <p>Public actions live; {testingActions} still in testing</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-border">
    <div class="container">
      <div class="track-dashboard">
        <section aria-labelledby="campaign-readiness-heading">
          <p class="section-label">Campaign readiness</p>
          <h2 id="campaign-readiness-heading">Current gates</h2>
          <div class="readiness-grid">
            {campaignEntries.map((campaign) => (
              <article class="readiness-card">
                <div class="eyebrow-row">
                  <span>{severityLabel(campaign.data.severity)}</span>
                  <StatusPill value={campaign.data.status} />
                </div>
                <h3><a href={`/campaigns/${campaign.data.slug}/`}>{campaign.data.title}</a></h3>
                <dl class="metadata-list">
                  <div>
                    <dt>Action</dt>
                    <dd>{statusLabel(campaign.data.primaryAction.status)}</dd>
                  </div>
                  <div>
                    <dt>Legal review</dt>
                    <dd>{reviewLabel(campaign.data.legalReviewStatus)}</dd>
                  </div>
                  <div>
                    <dt>Evidence</dt>
                    <dd>{confidenceLabel(campaign.data.confidenceLabel)}</dd>
                  </div>
                  <div>
                    <dt>Endpoint</dt>
                    <dd>{campaign.data.measurableEndpoint}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        </section>

        <aside class="sidebar-panel">
          <p class="section-label">Review queue</p>
          <h2>{reviewQueue} campaign{reviewQueue === 1 ? '' : 's'} need final review</h2>
          <p>Action Network delivery, representative targeting, legal wording and scientific review stay visible until each gate is cleared.</p>
          <ButtonLink href="/take-action/" variant="secondary">Review action gates</ButtonLink>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section-border">
    <div class="container">
      <div class="timeline-columns">
        <section>
          <p class="section-label">Platform updates</p>
          <div class="timeline-list">
            {platformUpdates.map((item) => (
              <article class="timeline-item">
                <time datetime={item.data.date}>{item.data.date}</time>
                <h2>{item.data.title}</h2>
                <p class="timeline-item__campaign">{item.data.area}</p>
                <p>{item.data.summary}</p>
                <StatusPill value={item.data.status} />
              </article>
            ))}
          </div>
        </section>

        <section>
          <p class="section-label">Campaign updates</p>
          <div class="timeline-list">
            {progress.map((item) => {
              const campaign = campaignsById.get(item.data.campaignId);
              return (
                <article class="timeline-item">
                  <time datetime={item.data.date}>{item.data.date}</time>
                  <h2>{item.data.title}</h2>
                  {campaign && <p class="timeline-item__campaign">{campaign.data.title}</p>}
                  <p>{item.data.summary}</p>
                  <StatusPill value={item.data.status} />
                </article>
              );
            })}
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="section section-border">
    <div class="container">
      <p class="section-label">Correction ledger</p>
      <div class="correction-list">
        {corrections.map(({ campaign, correction }) => (
          <article class="timeline-item">
            <h2>{campaign.data.title}</h2>
            <p>{correction.summary}</p>
            <StatusPill value={correction.status} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="callout-band">
    <div class="container">
      <div>
        <p class="section-label">Corrections</p>
        <h2>Challenge a claim, fix the record.</h2>
        <p>Send the page, the disputed claim and the source material that should change it.</p>
      </div>
      <ButtonLink href="/corrections/" variant="primary">Request correction</ButtonLink>
    </div>
  </section>
</BaseLayout>
