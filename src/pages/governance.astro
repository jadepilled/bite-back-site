---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
---

<BaseLayout
  title="Governance"
  description="Bite Back governance should include responsible people, conflicts registers, financial controls, complaints processes and privacy safeguards."
>
  <PageHeader
    eyebrow="Governance"
    title="Public accountability applies inward too."
    intro="Bite Back should publish funder categories, conflicts, methods, corrections, governance documents and campaign progress."
  />

  <section class="section">
    <div class="container">
      <div class="page-grid">
        <article class="pathway">
          <strong>Charity readiness</strong>
          <p>Resolve legal structure, charitable purpose, campaigning boundaries and fundraising law before scaling.</p>
        </article>
        <article class="pathway">
          <strong>Board responsibility</strong>
          <p>Maintain conflicts register, risk register, financial controls, privacy oversight and campaign approval checks.</p>
        </article>
        <article class="pathway">
          <strong>Safeguarding</strong>
          <p>Reject violence, intimidation, harassment, property damage, threats and misleading evidence.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-border">
    <div class="container reading-width">
      <h2>Minimum governance pack</h2>
      <ul class="check-list">
        <li><span>Constitution or governing rules.</span></li>
        <li><span>Conflict of interest policy and register.</span></li>
        <li><span>Privacy policy and data retention schedule.</span></li>
        <li><span>Campaign approval checklist.</span></li>
        <li><span>Complaints and corrections process.</span></li>
      </ul>
    </div>
  </section>
</BaseLayout>
