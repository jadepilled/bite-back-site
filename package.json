{
  "name": "bite-back-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:content && astro build",
    "preview": "astro preview",
    "check": "astro check && npm run validate:content",
    "validate:content": "node scripts/validate-content.mjs",
    "process:logo": "node scripts/process-logo.mjs",
    "news:update": "node scripts/update-news.mjs",
    "test": "npm run check && npm run build && npm run test:a11y",
    "test:a11y": "playwright test"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@lucide/astro": "^1.23.0",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "fast-xml-parser": "^5.9.3",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.4"
  }
}
